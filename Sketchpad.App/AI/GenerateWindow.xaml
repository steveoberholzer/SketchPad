<Window x:Class="Sketchpad.App.AI.GenerateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Generate with AI" Height="580" Width="780"
        MinHeight="440" MinWidth="560"
        Background="#F8F8F6"
        WindowStartupLocation="CenterOwner">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="#F0F0EE"
                BorderBrush="#CCCCCC"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <StackPanel>
                <TextBlock Text="Generate with AI" FontSize="15" FontWeight="SemiBold" Foreground="#2A2A2A"/>
                <TextBlock FontSize="11" Foreground="#777777" Margin="0,2,0,0">
                    Describe your screen in plain English — Claude will write the Sketchpad DSL.
                    Unknown controls are automatically substituted with the closest available element.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Bottom bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#F0F0EE"
                BorderBrush="#CCCCCC"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <DockPanel>
                <TextBlock x:Name="StatusText"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="11" Foreground="#777777"
                           Text="Enter a description and click Generate."/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="InsertButton"
                            Content="Insert into Editor"
                            IsEnabled="False"
                            Click="Insert_Click"
                            Padding="14,6" Margin="0,0,8,0"
                            FontSize="12"/>
                    <Button Content="Close"
                            Click="Close_Click"
                            Padding="14,6"
                            FontSize="12"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Prompt + API key section -->
            <Border Grid.Row="0"
                    Padding="16,14"
                    Background="#F8F8F6"
                    BorderBrush="#CCCCCC"
                    BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="Describe your screen:" FontSize="12" Foreground="#2A2A2A" Margin="0,0,0,5"/>
                    <TextBox x:Name="PromptBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="80"
                             Padding="8"
                             FontSize="12"
                             VerticalScrollBarVisibility="Auto"
                             BorderBrush="#CCCCCC"
                             Background="White"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Anthropic API Key:"
                                   VerticalAlignment="Center"
                                   FontSize="12" Foreground="#2A2A2A"
                                   Margin="0,0,10,0"/>
                        <PasswordBox x:Name="ApiKeyBox"
                                     Grid.Column="1"
                                     Padding="8,5"
                                     FontSize="12"
                                     BorderBrush="#CCCCCC"
                                     VerticalContentAlignment="Center"/>
                        <Button x:Name="GenerateButton"
                                Grid.Column="2"
                                Content="Generate"
                                Click="Generate_Click"
                                Padding="18,6"
                                Margin="10,0,0,0"
                                FontSize="12"
                                FontWeight="SemiBold"/>
                    </Grid>
                    <TextBlock FontSize="10" Foreground="#AAAAAA" Margin="0,5,0,0">
                        Key is saved to %APPDATA%\Sketchpad\settings.json — never leaves your machine.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- DSL preview -->
            <Border Grid.Row="1" Background="White">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="16,7,16,7"
                            Background="#F8F8F6"
                            BorderBrush="#CCCCCC"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="Generated DSL:" FontSize="12" Foreground="#555555"/>
                    </Border>
                    <avalon:TextEditor x:Name="DslPreview"
                                       IsReadOnly="True"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       ShowLineNumbers="True"
                                       WordWrap="False"
                                       HorizontalScrollBarVisibility="Auto"
                                       VerticalScrollBarVisibility="Auto"
                                       Padding="8"
                                       Background="#FAFAF8"/>
                </DockPanel>
            </Border>
        </Grid>

    </DockPanel>
</Window>
