<Window x:Class="Sketchpad.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Sketchpad" Height="700" Width="1100"
        MinHeight="400" MinWidth="600"
        Background="#F8F8F6">

    <DockPanel>
        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top" Background="#F0F0EE" FontSize="12"
              BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <MenuItem Header="_File">
                <MenuItem Header="_New"      Click="New_Click"        InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open…"    Click="Open_Click"       InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="_Save"     Click="Save_Click"       InputGestureText="Ctrl+S"/>
                <MenuItem Header="Save _As…" Click="SaveAs_Click"/>
                <Separator/>
                <MenuItem Header="Export _HTML…" Click="ExportHtml_Click"/>
            </MenuItem>
            <MenuItem Header="_Samples" Click="Samples_Click"/>
        </Menu>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="#F8F8F6"
                BorderBrush="#CCCCCC"
                BorderThickness="0,0,0,1"
                Padding="8,5">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="New"     Click="New_Click"    Padding="8,3" Margin="0,0,4,0" FontSize="12"/>
                    <Button Content="Open"    Click="Open_Click"   Padding="8,3" Margin="0,0,4,0" FontSize="12"/>
                    <Button Content="Save"    Click="Save_Click"   Padding="8,3" Margin="0,0,4,0" FontSize="12"/>
                    <Separator Margin="4,0"/>
                    <Button Content="Samples…" Click="Samples_Click" Padding="8,3" Margin="0,0,4,0" FontSize="12"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Text="Renderer:" VerticalAlignment="Center" Margin="0,0,6,0"
                               FontSize="12" Foreground="#555555"/>
                    <ComboBox x:Name="RendererCombo" Width="130" FontSize="12"
                              SelectionChanged="RendererCombo_SelectionChanged"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#F0F0EE"
                BorderBrush="#CCCCCC"
                BorderThickness="0,1,0,0"
                Padding="10,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusText"       FontSize="11" Foreground="#555555" VerticalAlignment="Center"/>
                <TextBlock Text=" | " FontSize="11"  Foreground="#AAAAAA" VerticalAlignment="Center"/>
                <TextBlock x:Name="NodeCountText"    FontSize="11" Foreground="#555555" VerticalAlignment="Center"/>
                <TextBlock Text=" | " FontSize="11"  Foreground="#AAAAAA" VerticalAlignment="Center"/>
                <TextBlock x:Name="RendererNameText" FontSize="11" Foreground="#555555" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Editor | Splitter | Preview -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="3*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- AvalonEdit editor -->
            <avalon:TextEditor x:Name="EditorBox"
                               Grid.Column="0"
                               FontFamily="Consolas"
                               FontSize="13"
                               ShowLineNumbers="True"
                               WordWrap="False"
                               HorizontalScrollBarVisibility="Auto"
                               VerticalScrollBarVisibility="Auto"
                               Padding="4"
                               Background="#FAFAF8"
                               Foreground="#2A2A2A"
                               BorderThickness="0"/>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="#CCCCCC"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Preview -->
            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1,0,0,0">
                <ScrollViewer x:Name="PreviewScroll"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <ContentPresenter x:Name="PreviewHost"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
