<Window x:Class="Sketchpad.App.SamplesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Sample Layouts" Height="620" Width="1000"
        MinHeight="400" MinWidth="640"
        Background="#F8F8F6"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sample list -->
            <Border Grid.Column="0"
                    BorderBrush="#CCCCCC" BorderThickness="0,0,0,0"
                    Background="#F0F0EE">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="12,10" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                        <TextBlock Text="Samples" FontSize="13" FontWeight="SemiBold" Foreground="#2A2A2A"/>
                    </Border>
                    <ListBox x:Name="SampleList"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="6"
                             SelectionChanged="SampleList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding"       Value="10,8"/>
                                <Setter Property="Margin"        Value="0,2"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background"    Value="Transparent"/>
                                <Setter Property="Cursor"        Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#DDEEFF"/>
                                        <Setter Property="Foreground" Value="#1565C0"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E8E8E8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Description}" FontSize="10"
                                               Foreground="#777777" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="#CCCCCC" ResizeBehavior="PreviousAndNext"/>

            <!-- DSL preview -->
            <Border Grid.Column="2" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Background="White">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="12,8"
                            Background="#F8F8F6" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                        <TextBlock x:Name="PreviewTitle" FontSize="12" Foreground="#555555"
                                   Text="Select a sample to preview its markup."/>
                    </Border>
                    <avalon:TextEditor x:Name="DslPreview"
                                       IsReadOnly="True"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       ShowLineNumbers="True"
                                       WordWrap="False"
                                       HorizontalScrollBarVisibility="Auto"
                                       VerticalScrollBarVisibility="Auto"
                                       Padding="8"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Bottom bar -->
        <Border Grid.Row="1"
                Background="#F0F0EE"
                BorderBrush="#CCCCCC"
                BorderThickness="0,1,0,0"
                Padding="12,8">
            <DockPanel>
                <TextBlock x:Name="HintText"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="11" Foreground="#777777"
                           Text="Inserting a sample will replace the current editor content."/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="UseButton"
                            Content="Use This Sample"
                            IsEnabled="False"
                            Click="UseButton_Click"
                            Padding="14,6" Margin="0,0,8,0"
                            FontSize="12"/>
                    <Button Content="Close"
                            Click="Close_Click"
                            Padding="14,6"
                            FontSize="12"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
